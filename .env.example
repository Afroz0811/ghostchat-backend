# ── GhostChat Backend Environment Variables ──────────────────────────────────
# Copy this to .env and fill in your values

# MongoDB connection string (get free at mongodb.com/atlas)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/ghostchat

# JWT Secret - use a long random string (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-this-to-something-random-and-long

# AES Encryption secret - use a long random string
ENCRYPTION_SECRET=your-encryption-secret-change-this-too-make-it-very-long

# Port (Railway sets this automatically)
PORT=3001
